{
  // 스타일(줄바꿈·빈줄·공백·heading 스타일 등)은 검사하지 않는다.
  // 실제로 렌더링을 깨뜨리는 문법 오류만 잡는다.
  "config": {
    "default": false,
    "MD011": true, // reversed link: (text)[url] — 링크가 렌더되지 않음
    "MD038": true, // 코드 스팬 안쪽 공백 — 코드 스팬이 깨짐
    "MD039": true, // 링크 텍스트 양끝 공백
    "MD042": true // 빈 링크 []() — 동작하지 않는 링크
  },
  "globs": ["data/**/*.md"]
}
